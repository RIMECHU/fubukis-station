---
/**
 * SocialsCard Component
 * Displays social media links
 */

import Card from './Card.astro';
import CardHeader from './CardHeader.astro';
import type { Social } from '../types';
import { Icon } from 'astro-icon/components';
import { defaultLang, type Lang, useTranslations } from '../i18n/config';

interface Props {
	socials: Social[];
	lang?: Lang;
}

const { socials, lang: langProp } = Astro.props as Props;
const lang = langProp ?? defaultLang;
const t = useTranslations(lang);
---

<Card>
	<CardHeader title={t('home.socials.title')} />
	
	<ul class="list-none p-0 m-0">
		{socials.map((social) => (
			<li class="mb-2 last:mb-0">
				<a 
					href={social.url} 
					class="flex items-center gap-2 text-white hover:text-white no-underline text-sm"
					target="_blank"
					rel="noopener noreferrer"
				>
					<Icon
						name={social.icon}
						class="w-5 h-5 text-[var(--color-primary)] flex-shrink-0 iconify"
						style="filter: drop-shadow(0 0 4px var(--color-primary))"
					/>
					<span>{social.name}</span>
				</a>
			</li>
		))}
	</ul>
</Card>
