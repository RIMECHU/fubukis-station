---
---
<div id="opening-animation" class="fixed inset-0 z-[9999] pointer-events-auto overflow-hidden select-none" style="display:none" aria-hidden="true">

    <!-- ═══════════ SCENE SVG ═══════════ -->
    <svg id="scene" class="absolute inset-0 z-10 w-full h-full"
         viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice"
         xmlns="http://www.w3.org/2000/svg">
        <defs>
            <!-- Night sky gradient -->
            <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#06061a"/>
                <stop offset="50%" stop-color="#0f1128"/>
                <stop offset="100%" stop-color="#0d1117"/>
            </linearGradient>

            <!-- Moon glow -->
            <radialGradient id="moonGrad" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#fffef5"/>
                <stop offset="70%" stop-color="#f5f0e0"/>
                <stop offset="100%" stop-color="#e8dcc8"/>
            </radialGradient>

            <!-- Moon outer glow filter -->
            <filter id="moonGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="30" result="blur"/>
                <feMerge>
                    <feMergeNode in="blur"/>
                    <feMergeNode in="blur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>

            <!-- Petal blur for depth -->
            <filter id="blurFar">
                <feGaussianBlur stdDeviation="1.5"/>
            </filter>
            <filter id="blurNear">
                <feGaussianBlur stdDeviation="0.5"/>
            </filter>

            <!-- Mist gradient -->
            <linearGradient id="mistGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#0d1117" stop-opacity="0"/>
                <stop offset="100%" stop-color="#0d1117" stop-opacity="0.9"/>
            </linearGradient>

            <!-- Branch gradient for organic feel -->
            <linearGradient id="branchGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#1a1518"/>
                <stop offset="100%" stop-color="#0d0b0e"/>
            </linearGradient>
        </defs>

        <!-- Sky -->
        <rect width="1920" height="1080" fill="url(#skyGrad)"/>

        <!-- ── Stars ── -->
        <g id="stars" opacity="0.6">
            <circle cx="200" cy="120" r="1.2" fill="#fff"/>
            <circle cx="450" cy="80" r="0.8" fill="#fff"/>
            <circle cx="700" cy="200" r="1.0" fill="#fff"/>
            <circle cx="300" cy="300" r="0.7" fill="#fff"/>
            <circle cx="850" cy="100" r="1.3" fill="#fff"/>
            <circle cx="1000" cy="250" r="0.6" fill="#fff"/>
            <circle cx="120" cy="400" r="0.9" fill="#fff"/>
            <circle cx="550" cy="350" r="0.7" fill="#fff"/>
            <circle cx="1600" cy="180" r="1.0" fill="#fff"/>
            <circle cx="1750" cy="350" r="0.8" fill="#fff"/>
            <circle cx="150" cy="550" r="0.6" fill="#fff"/>
            <circle cx="1800" cy="500" r="0.9" fill="#fff"/>
            <circle cx="900" cy="400" r="0.7" fill="#fff"/>
            <circle cx="1100" cy="150" r="1.1" fill="#fff"/>
        </g>

        <!-- ── Moon ── -->
        <g id="moon-group">
            <circle cx="1700" cy="240" r="150" fill="#f5f0e0" opacity="0.08" filter="url(#moonGlow)"/>
            <circle cx="1700" cy="240" r="130" fill="url(#moonGrad)" filter="url(#moonGlow)" opacity="0.9"/>
            <!-- Moon craters (subtle) -->
            <ellipse cx="1655" cy="205" rx="28" ry="23" fill="#e8dcc8" opacity="0.25"/>
            <ellipse cx="1725" cy="260" rx="18" ry="16" fill="#e8dcc8" opacity="0.2"/>
            <ellipse cx="1680" cy="285" rx="22" ry="13" fill="#e8dcc8" opacity="0.15"/>
            <ellipse cx="1740" cy="205" rx="10" ry="9" fill="#e8dcc8" opacity="0.2"/>
        </g>

        <!-- ── Clouds ── -->
        <g id="clouds" fill="#ffffff" opacity="0.04">
            <g class="cloud" style="animation: cloudDrift1 60s linear infinite;">
                <ellipse cx="500" cy="350" rx="200" ry="40"/>
                <ellipse cx="580" cy="340" rx="140" ry="35"/>
                <ellipse cx="440" cy="345" rx="120" ry="30"/>
            </g>
            <g class="cloud" style="animation: cloudDrift2 80s linear infinite;">
                <ellipse cx="1000" cy="250" rx="180" ry="35"/>
                <ellipse cx="1080" cy="242" rx="130" ry="30"/>
                <ellipse cx="940" cy="245" rx="100" ry="28"/>
            </g>
            <g class="cloud" style="animation: cloudDrift3 70s linear infinite;">
                <ellipse cx="300" cy="500" rx="160" ry="30"/>
                <ellipse cx="360" cy="495" rx="110" ry="28"/>
            </g>
            <g class="cloud" style="animation: cloudDrift1 90s linear infinite;">
                <ellipse cx="1800" cy="480" rx="120" ry="28"/>
                <ellipse cx="1860" cy="475" rx="100" ry="24"/>
            </g>
        </g>

        <!-- ── Sakura Branches (Top-Right) ── -->
        <g id="branches" fill="none" stroke="url(#branchGrad)" stroke-linecap="round" stroke-linejoin="round">
            <!-- Main trunk from top-right -->
            <path d="M 1920,-10 Q 1820,60 1720,120 Q 1620,180 1520,250 Q 1440,310 1360,380"
                  stroke-width="14" opacity="0.9"/>
            <!-- Tapering continuation -->
            <path d="M 1360,380 Q 1300,430 1240,480 Q 1200,510 1160,540"
                  stroke-width="8" opacity="0.85"/>
            <path d="M 1160,540 Q 1130,560 1100,580"
                  stroke-width="4" opacity="0.8"/>

            <!-- Sub-branch 1 -->
            <path d="M 1720,120 Q 1660,90 1580,70 Q 1520,55 1460,50"
                  stroke-width="8" opacity="0.85"/>
            <path d="M 1580,70 Q 1540,55 1500,45"
                  stroke-width="4" opacity="0.8"/>

            <!-- Sub-branch 2 -->
            <path d="M 1520,250 Q 1440,230 1360,220 Q 1300,215 1240,215"
                  stroke-width="6" opacity="0.8"/>
            <path d="M 1360,220 Q 1320,205 1280,190"
                  stroke-width="3" opacity="0.75"/>

            <!-- Sub-branch 3 -->
            <path d="M 1440,310 Q 1360,340 1280,370 Q 1220,390 1160,400"
                  stroke-width="5" opacity="0.8"/>
            <path d="M 1280,370 Q 1240,380 1200,395"
                  stroke-width="3" opacity="0.75"/>

            <!-- Sub-branch 4 -->
            <path d="M 1360,380 Q 1400,410 1440,440 Q 1460,455 1480,470"
                  stroke-width="4" opacity="0.75"/>

            <!-- Branch from top-left (smaller) -->
            <path d="M -10,50 Q 80,100 160,160 Q 220,210 280,270"
                  stroke-width="8" opacity="0.75"/>
            <path d="M 280,270 Q 320,310 350,350"
                  stroke-width="4" opacity="0.7"/>
            <path d="M 160,160 Q 200,140 240,120 Q 270,105 300,95"
                  stroke-width="4" opacity="0.7"/>
            <path d="M 220,210 Q 250,240 280,260 Q 300,270 320,280"
                  stroke-width="3" opacity="0.65"/>
        </g>

        <!-- ── Flowers on Branches (tiny pink clusters) ── -->
        <g id="branch-flowers" fill="#ffb7c5" opacity="0.7">
            <!-- Cluster near sub-branch 1 tip -->
            <circle cx="1500" cy="45" r="4"/>
            <circle cx="1493" cy="42" r="3"/>
            <circle cx="1506" cy="48" r="2.5"/>
            <circle cx="1510" cy="40" r="3.5"/>
            <!-- Cluster on sub-branch 2 -->
            <circle cx="1280" cy="190" r="3.5"/>
            <circle cx="1273" cy="188" r="3"/>
            <circle cx="1286" cy="193" r="2.5"/>
            <!-- Cluster on sub-branch 3 -->
            <circle cx="1200" cy="395" r="3"/>
            <circle cx="1195" cy="392" r="2.5"/>
            <circle cx="1204" cy="398" r="2"/>
            <!-- Cluster near main branch end -->
            <circle cx="1100" cy="580" r="3"/>
            <circle cx="1094" cy="575" r="2.5"/>
            <circle cx="1106" cy="583" r="2"/>
            <circle cx="1090" cy="570" r="3.5"/>
            <!-- Scattered along main trunk -->
            <circle cx="1620" cy="180" r="3"/>
            <circle cx="1614" cy="177" r="2.5"/>
            <circle cx="1550" cy="240" r="2.5"/>
            <circle cx="1470" cy="305" r="3"/>
            <circle cx="1464" cy="302" r="2"/>
            <!-- Branch 4 flowers -->
            <circle cx="1480" cy="470" r="2.5"/>
            <circle cx="1476" cy="467" r="2"/>
            <!-- Left branch flowers -->
            <circle cx="300" cy="95" r="3"/>
            <circle cx="295" cy="92" r="2.5"/>
            <circle cx="350" cy="350" r="3"/>
            <circle cx="345" cy="347" r="2.5"/>
            <circle cx="354" cy="353" r="2"/>
            <circle cx="320" cy="280" r="2.5"/>
        </g>

        <!-- ── Mist layer (bottom) ── -->
        <rect x="0" y="700" width="1920" height="380" fill="url(#mistGrad)"/>
        <g class="mist-wisp" opacity="0.06" fill="#ffffff">
            <ellipse cx="400" cy="900" rx="500" ry="60"/>
            <ellipse cx="1000" cy="950" rx="600" ry="50"/>
            <ellipse cx="1500" cy="880" rx="450" ry="55"/>
        </g>

        <!-- ── Falling Petals (dynamically added here) ── -->
        <g id="petals-group"></g>
    </svg>

    <!-- ═══════════ CONTENT OVERLAY ═══════════ -->
    <div id="intro-content" class="absolute inset-0 z-30 flex flex-col items-center justify-center">
        <div class="relative overflow-hidden p-4">
            <h1 id="logo-text" class="text-6xl md:text-9xl lg:text-10xl font-black tracking-tighter text-foreground opacity-0"
                data-value="FUBUKI">FUBUKI</h1>
            <div id="scan-line" class="absolute top-0 left-0 w-full h-[2px] bg-primary opacity-0"></div>
        </div>
        <div class="mt-4 overflow-hidden">
            <span id="sub-text" class="font-mono text-xs md:text-sm lg:text-base text-primary tracking-[1em] uppercase opacity-0 translate-y-4 transition-all duration-700 delay-300 block">
                吹雪降臨
            </span>
        </div>
    </div>

    <!-- Flash -->
    <div id="flash-overlay" class="absolute inset-0 z-50 opacity-0 pointer-events-none" style="background: #fff0f5;"></div>
</div>

<!-- ═══════════ INLINE SCRIPT (immediate check) ═══════════ -->
<script is:inline>
    try {
        const hasPlayed = window.__introPlayed;
	    const introEnabled = localStorage.getItem('intro-enabled') !== 'false';
        if (introEnabled && !hasPlayed) {
            window.__introPlayed = true;
            var el = document.getElementById('opening-animation');
            if (el) el.style.display = 'block';
            document.body.classList.add('is-animating');
        } else {
            const c = document.getElementById('opening-animation');
            if (c) c.style.display = 'none';
            document.body.classList.add('animation-triggered');
        }
    } catch (e) {}
</script>

<!-- ═══════════ MAIN ANIMATION SCRIPT ═══════════ -->
<script>
    const LETTERS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';

    // Sakura petal SVG path (teardrop/petal shape, pointing up)
    const PETAL_PATH = 'M0,-12 C-9,-12 -15,-3 -15,7 C-15,15 -7,20 0,26 C7,20 15,15 15,7 C15,-3 9,-12 0,-12Z';

    const PETAL_COLORS = [
        '#ffb7c5', '#ffd1dc', '#f8bbd0', '#ff9eb5',
        '#fce4ec', '#fff0f5', '#ffccd5', '#ffc2d1',
        '#ffe4e1', '#fde0e8', '#ffd6e0', '#ffbfd5',
    ];

    interface Petal {
        el: SVGElement;
        x: number;          // viewBox x
        y: number;          // viewBox y
        size: number;
        speed: number;
        swayAmp: number;
        swayFreq: number;
        swayPhase: number;
        rotation: number;
        rotSpeed: number;
        opacity: number;
        filterId: string;   // depth blur
    }

    function startAnimation() {
        const container = document.getElementById('opening-animation');
        if (!container) return;

        if (localStorage.getItem('intro-enabled') === 'false') {
            container.remove();
            document.body.classList.remove('is-animating');
            document.body.classList.add('animation-triggered');
            return;
        }

        document.body.classList.add('is-animating');

        const scene = document.getElementById('scene') as unknown as SVGElement;
        const petalsGroup = document.getElementById('petals-group') as unknown as SVGElement;
        const flash = document.getElementById('flash-overlay');
        const content = document.getElementById('intro-content');
        const logoText = document.getElementById('logo-text');
        const subText = document.getElementById('sub-text');
        const scanLine = document.getElementById('scan-line');

        if (!scene || !petalsGroup || !flash || !content || !logoText) return;

        const VB_W = 1920;
        const VB_H = 1080;

        // ── Create Falling Petals ──
        const PETAL_COUNT = 45;
        const petals: Petal[] = [];
        const svgNS = 'http://www.w3.org/2000/svg';

        for (let i = 0; i < PETAL_COUNT; i++) {
            const color = PETAL_COLORS[Math.floor(Math.random() * PETAL_COLORS.length)];
            const size = 8 + Math.random() * 20;
            const depth = Math.random();
            const filterId = depth > 0.6 ? 'blurFar' : depth > 0.3 ? 'blurNear' : '';

            const g = document.createElementNS(svgNS, 'g');
            const path = document.createElementNS(svgNS, 'path');
            path.setAttribute('d', PETAL_PATH);
            path.setAttribute('fill', color);
            if (filterId) path.setAttribute('filter', `url(#${filterId})`);
            g.appendChild(path);
            petalsGroup.appendChild(g);

            petals.push({
                el: g,
                x: Math.random() * VB_W,
                y: -60 - Math.random() * VB_H * 0.9,
                size,
                speed: 25 + Math.random() * 55,
                swayAmp: 15 + Math.random() * 55,
                swayFreq: 0.25 + Math.random() * 0.65,
                swayPhase: Math.random() * Math.PI * 2,
                rotation: Math.random() * 360,
                rotSpeed: (Math.random() - 0.5) * 35,
                opacity: 0.5 + Math.random() * 0.5,
                filterId,
            });
        }

        // ── Decode Effect ──
        const runDecodeEffect = (el: HTMLElement, finalText: string, duration: number) => {
            let it = 0;
            const total = finalText.length;
            const intv = 50;
            const inc = total / (duration / intv);
            const timer = setInterval(() => {
                el.innerText = finalText.split('').map((c, i) => i < it ? c : LETTERS[Math.floor(Math.random() * LETTERS.length)]).join('');
                if (it >= total) { clearInterval(timer); el.innerText = finalText; }
                it += inc;
            }, intv);
        };

        // ── Animation Loop ──
        let animId: number;
        let startTs: number | null = null;
        const WIND_START = 3200;   // wind gust begins
        const TOTAL_DUR = 4800;    // total animation ms

        const loop = (ts: number) => {
            if (!startTs) startTs = ts;
            const elapsed = ts - startTs;
            const dt = 1 / 60; // fixed timestep for smooth physics

            const windActive = elapsed > WIND_START;
            const windProgress = windActive ? Math.min((elapsed - WIND_START) / 1400, 1) : 0;
            const windStrength = windProgress < 0.01 ? 0 : windProgress * windProgress * 350; // px/s in viewBox

            petals.forEach(p => {
                // Fall
                p.y += p.speed * dt;

                // Sway
                p.x += Math.sin(ts * 0.001 * p.swayFreq + p.swayPhase) * p.swayAmp * dt;
                p.rotation += p.rotSpeed * dt;

                // Wind: blow right and slightly up
                if (windActive) {
                    p.x += windStrength * dt;
                    p.y -= windStrength * 0.25 * dt;
                    p.opacity = Math.max(0, p.opacity - 0.9 * dt);
                }

                // Recycle petals that exit screen before wind
                if (!windActive && (p.y > VB_H + 60 || p.x < -60 || p.x > VB_W + 60)) {
                    p.y = -40 - Math.random() * 50;
                    p.x = Math.random() * VB_W;
                }

                // Apply transform
                p.el.setAttribute('transform',
                    `translate(${p.x.toFixed(1)}, ${p.y.toFixed(1)}) rotate(${p.rotation.toFixed(1)}) scale(${(p.size / 16).toFixed(2)})`);
                p.el.setAttribute('opacity', String(Math.max(0, +p.opacity.toFixed(3))));
            });

            if (elapsed > TOTAL_DUR) return;
            if (windActive && windProgress > 0.85 && petals.every(p => p.opacity <= 0)) return;

            animId = requestAnimationFrame(loop);
        };

        // ── Timeline ──
        (async () => {
            // Logo reveal
            logoText.style.opacity = '1';
            logoText.style.transition = 'filter 1.5s ease';
            logoText.style.filter = 'blur(0px)';

            runDecodeEffect(logoText, logoText.dataset.value || 'FUBUKI', 1500);

            setTimeout(() => {
                if (subText) {
                    const msgs = ['吹雪降臨', '桜吹雪', '花吹雪', '風花', '夢幻', '雪月花'];
                    subText.innerText = msgs[Math.floor(Math.random() * msgs.length)];
                    subText.classList.remove('opacity-0', 'translate-y-4');
                }
            }, 400);

            if (scanLine) {
                scanLine.style.transition = 'top 1500ms ease-in-out, opacity 0.5s';
                scanLine.style.opacity = '0.5';
                scanLine.style.top = '100%';
            }

            // Start petal animation
            animId = requestAnimationFrame(loop);

            // Wait for wind moment
            await new Promise(r => setTimeout(r, WIND_START));

            // Reveal page — landing animation & cleanup run concurrently
            document.body.classList.add('animation-triggered');

            // Soft pink flash
            flash.style.transition = 'opacity 0.3s ease-out';
            flash.style.opacity = '0.12';
            setTimeout(() => {
                flash.style.transition = 'opacity 1s ease-out';
                flash.style.opacity = '0';
            }, 80);

            // Fade out logo
            content.style.transition = 'opacity 0.5s ease';
            content.style.opacity = '0';

            // Cleanup after petals clear — non-blocking, landing animation plays simultaneously
            setTimeout(() => {
                document.body.classList.remove('is-animating');
                container.remove();
            }, 1400);
        })();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startAnimation);
    } else {
        startAnimation();
    }
</script>

<!-- ═══════════ STYLES ═══════════ -->
<style>
    /* Cloud drift animations */
    @keyframes cloudDrift1 {
        from { transform: translateX(0); }
        to   { transform: translateX(-300px); }
    }
    @keyframes cloudDrift2 {
        from { transform: translateX(0); }
        to   { transform: translateX(-400px); }
    }
    @keyframes cloudDrift3 {
        from { transform: translateX(0); }
        to   { transform: translateX(-250px); }
    }

    /* Star twinkle */
    #stars circle:nth-child(odd) {
        animation: twinkle 3s ease-in-out infinite;
    }
    #stars circle:nth-child(even) {
        animation: twinkle 4s ease-in-out 1.5s infinite;
    }
    @keyframes twinkle {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
    }
</style>

<style is:global>
    body.is-animating:not(.animation-triggered) .landing-section {
        opacity: 0 !important;
        transform: scale(0.95) translateY(30px);
        filter: blur(8px);
        pointer-events: none;
        will-change: transform, opacity, filter;
    }

    body.animation-triggered .landing-section {
        animation: landIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) both;
        pointer-events: auto;
    }

    body.animation-triggered .landing-section.delay-0   { animation-delay: 0ms; }
    body.animation-triggered .landing-section.delay-100 { animation-delay: 100ms; }
    body.animation-triggered .landing-section.delay-200 { animation-delay: 200ms; }
    body.animation-triggered .landing-section.delay-300 { animation-delay: 300ms; }
    body.animation-triggered .landing-section.delay-400 { animation-delay: 400ms; }
    body.animation-triggered .landing-section.delay-500 { animation-delay: 500ms; }

    @keyframes landIn {
        0%   { opacity: 0; transform: scale(0.95) translateY(30px); filter: blur(8px); }
        100% { opacity: 1; transform: scale(1) translateY(0);    filter: blur(0); }
    }
</style>
