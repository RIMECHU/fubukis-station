---
/**
 * LatestPosts Component
 * Displays latest blog posts
 */

import FormattedDate from './FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';
import { stripMarkdown } from '../utils/markdown';
import { getRelativeLocaleUrl } from '../i18n/config';
import { getPostBaseId } from '../i18n/i18n';

interface Props {
	posts: CollectionEntry<'blog'>[];
	lang?: import('../i18n/config').Lang;
}

const { posts, lang } = Astro.props;
---

<div class="flex flex-col gap-3 post-list">
		{posts.map((post) => (
			<a 
				href={lang ? getRelativeLocaleUrl(lang, `/blog/${getPostBaseId(post)}/`) : `/blog/${getPostBaseId(post)}/`}
				class="flex flex-col gap-2 p-3 border border-accent/40 text-white transition-all duration-150 hover:bg-primary/12.5 hover:border-primary focus-visible:outline-none focus-visible:bg-primary/12.5 focus-visible:border-primary"
			>
				<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
					<h3 class="text-sm font-semibold text-foreground m-0">{post.data.title}</h3>
					<time class="text-xs text-foreground/70 shrink-0">
						<FormattedDate date={post.data.pubDate} lang={lang} />
					</time>
				</div>
				{post.data.description && (
					<p class="text-xs text-foreground/70 m-0 leading-relaxed">
						{stripMarkdown(post.data.description)}
					</p>
				)}
			</a>
		))}
</div>

<style>
	/* Scoped style to prevent underline on post links */
	.post-list a {
		text-decoration: none;
	}
	
	.post-list a:hover {
		text-decoration: none;
	}
</style>
