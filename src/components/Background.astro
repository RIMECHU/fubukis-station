---
/**
 * Starfield Background
 * Canvas-based animated starfield with varying star sizes & twinkling
 */
---

<canvas id="starfield-canvas"></canvas>

<script>
    // ── Starfield Background: re-initializes after SPA navigations ──
    var _bgAnimId = 0;
    var _bgStars = [];
    var STAR_COUNT = 300;

    function initStarfield() {
        var canvas = document.getElementById('starfield-canvas');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        // Cancel previous animation loop
        if (_bgAnimId) cancelAnimationFrame(_bgAnimId);

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function createStars() {
            _bgStars = [];
            for (var i = 0; i < STAR_COUNT; i++) {
                var sizeRoll = Math.random();
                var r, baseAlpha;
                if (sizeRoll < 0.05) {
                    r = 1.8 + Math.random() * 1.2;
                    baseAlpha = 0.7 + Math.random() * 0.3;
                } else if (sizeRoll < 0.2) {
                    r = 1.0 + Math.random() * 0.8;
                    baseAlpha = 0.45 + Math.random() * 0.35;
                } else if (sizeRoll < 0.5) {
                    r = 0.5 + Math.random() * 0.5;
                    baseAlpha = 0.3 + Math.random() * 0.25;
                } else {
                    r = 0.2 + Math.random() * 0.4;
                    baseAlpha = 0.15 + Math.random() * 0.2;
                }

                _bgStars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: r,
                    baseAlpha: baseAlpha,
                    alpha: baseAlpha,
                    twinkleSpeed: 0.3 + Math.random() * 2.5,
                    twinkleOffset: Math.random() * Math.PI * 2,
                });
            }
        }

        function draw(now) {
            // Re-query canvas each frame to survive DOM swaps mid-animation
            var c = document.getElementById('starfield-canvas');
            if (!c) return;
            var cx = c.getContext('2d');
            if (!cx) return;

            cx.clearRect(0, 0, c.width, c.height);

            var grad = cx.createLinearGradient(0, 0, 0, c.height);
            grad.addColorStop(0, '#06061a');
            grad.addColorStop(0.6, '#0f1128');
            grad.addColorStop(1, '#0a0d14');
            cx.fillStyle = grad;
            cx.fillRect(0, 0, c.width, c.height);

            var t = now * 0.001;
            var stars = _bgStars;

            for (var i = 0; i < stars.length; i++) {
                var s = stars[i];
                var twinkle = Math.sin(t * s.twinkleSpeed + s.twinkleOffset);
                s.alpha = s.baseAlpha * (0.6 + 0.4 * twinkle);

                if (s.r > 1.2) {
                    cx.beginPath();
                    cx.arc(s.x, s.y, s.r * 3, 0, Math.PI * 2);
                    var glow = cx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r * 3);
                    glow.addColorStop(0, 'rgba(180,200,255,' + (s.alpha * 0.3) + ')');
                    glow.addColorStop(1, 'rgba(180,200,255,0)');
                    cx.fillStyle = glow;
                    cx.fill();
                }

                cx.beginPath();
                cx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                cx.fillStyle = 'rgba(255,255,255,' + s.alpha + ')';
                cx.fill();
            }

            for (var j = 0; j < 3; j++) {
                var sparkle = Math.abs(Math.sin(t * (4 + j * 1.7) + j));
                if (sparkle > 0.85) {
                    var s = stars[Math.floor(Math.random() * 10)];
                    if (s) {
                        cx.beginPath();
                        var cx2 = s.x, cy2 = s.y, len = s.r * 8 * sparkle;
                        cx.strokeStyle = 'rgba(255,255,255,' + (sparkle * 0.6) + ')';
                        cx.lineWidth = 0.5;
                        cx.moveTo(cx2 - len, cy2);
                        cx.lineTo(cx2 + len, cy2);
                        cx.moveTo(cx2, cy2 - len);
                        cx.lineTo(cx2, cy2 + len);
                        cx.stroke();
                    }
                }
            }

            _bgAnimId = requestAnimationFrame(draw);
        }

        resize();
        createStars();
        _bgAnimId = requestAnimationFrame(draw);
    }

    // Run on initial load
    setTimeout(initStarfield, 0);

    // Re-run after SPA navigations
    document.addEventListener('astro:after-swap', function() {
        setTimeout(initStarfield, 0);
    });

    // Resize handler (only needs to be attached once)
    if (!window.__bgResizeBound) {
        window.__bgResizeBound = true;
        window.addEventListener('resize', function() {
            initStarfield();
        });
    }
</script>

<style>
    #starfield-canvas {
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
    }
</style>
