---
import type { LinkCardProps } from '../config/links';

interface Props extends LinkCardProps {}

const { link, linkText, description, icon } = Astro.props;

// Fallback icon
const fallbackIcon = '/favicon.png';
---

<a 
	href={link}
	class="link-card"
	target="_blank"
	rel="noopener noreferrer"
>
	<div class="link-icon">
		<img 
			src={icon || fallbackIcon} 
			alt={linkText}
			loading="lazy"
			onerror={`this.onerror=null; this.src='${fallbackIcon}'`}
		/>
	</div>
	<div class="link-content">
		<h3 class="link-title">{linkText}</h3>
		<p class="link-description">{description}</p>
	</div>
</a>

<style>
	.link-card {
		display: flex;
		gap: 0.75rem;
		padding: 0.875rem;
		border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
		text-decoration: none;
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	.link-card::before {
		content: '';
		position: absolute;
		inset: -20px;
		background: radial-gradient(
			ellipse 80% 50% at 50% 50%,
			color-mix(in srgb, var(--color-primary) 15%, transparent),
			transparent 70%
		);
		opacity: 0;
		transition: opacity 400ms ease;
		pointer-events: none;
		filter: blur(20px);
	}

	.link-card:hover,
	.link-card:focus-visible {
		background-color: color-mix(in srgb, var(--color-primary) 3%, transparent);
		border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
		box-shadow: 
			0 0 40px color-mix(in srgb, var(--color-primary) 12%, transparent),
			inset 0 0 20px color-mix(in srgb, var(--color-primary) 5%, transparent);
	}

	.link-card:hover::before,
	.link-card:focus-visible::before {
		opacity: 1;
	}

	.link-icon {
		flex-shrink: 0;
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
		border-radius: 4px;
		overflow: hidden;
		background: color-mix(in srgb, var(--color-foreground) 2%, transparent);
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.link-card:hover .link-icon,
	.link-card:focus-visible .link-icon {
		border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
		box-shadow: 0 0 20px color-mix(in srgb, var(--color-primary) 15%, transparent);
	}

	.link-icon img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.link-card:hover .link-icon img,
	.link-card:focus-visible .link-icon img {
		transform: scale(1.1);
	}

	.link-content {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.link-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-foreground);
		transition: color 200ms ease;
		line-height: 1.4;
	}

	.link-card:hover .link-title,
	.link-card:focus-visible .link-title {
		color: var(--color-primary-light);
	}

	.link-description {
		margin: 0;
		font-size: 0.8125rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
		transition: color 200ms ease;
	}

	.link-card:hover .link-description,
	.link-card:focus-visible .link-description {
		color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
	}

	@media (min-width: 640px) {
		.link-card {
			gap: 1rem;
			padding: 1rem;
		}

		.link-icon {
			width: 64px;
			height: 64px;
		}

		.link-title {
			font-size: 1.125rem;
		}

		.link-description {
			font-size: 0.875rem;
		}
	}
</style>
