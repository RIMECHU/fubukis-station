---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/Card.astro';
import CardHeader from '../../components/CardHeader.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { stripMarkdown } from '../../utils/markdown';
import { defaultLang, getRelativeLocaleUrl, monthNames as monthNamesByLang, resolveLang, useTranslations } from '../../i18n/config';
import type { Lang } from '../../i18n/config';
import { getAllPostsWithPreferredLang, getPostBaseId } from '../../i18n/i18n';

const { lang: langProp } = Astro.props as { lang?: Lang };
const lang = langProp ?? resolveLang(Astro.url.pathname) ?? defaultLang;

const posts = await getAllPostsWithPreferredLang(lang);

const t = useTranslations(lang);
const monthNames = monthNamesByLang[lang];

// Collect all tags with their counts and sort by count (descending)
const tagCounts = new Map<string, number>();
posts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

const sortedTags = Array.from(tagCounts.entries())
	.sort((a, b) => b[1] - a[1]) // Sort by count descending
	.map(([tag, count]) => ({ tag, count }));

// Collect all dates with their counts - group by year and month
interface MonthData {
	month: number;
	count: number;
}

interface YearData {
	year: number;
	count: number;
	months: MonthData[];
}

const dateGroups = new Map<number, Map<number, number>>();
posts.forEach((post) => {
	const date = post.data.pubDate;
	const year = date.getFullYear();
	const month = date.getMonth() + 1; // 1-12

	if (!dateGroups.has(year)) {
		dateGroups.set(year, new Map());
	}
	const yearMap = dateGroups.get(year)!;
	yearMap.set(month, (yearMap.get(month) || 0) + 1);
});

// Convert to sorted array (years descending, months descending)
const sortedDateGroups: YearData[] = Array.from(dateGroups.entries())
	.sort((a, b) => b[0] - a[0]) // Sort years descending
	.map(([year, monthsMap]) => ({
		year,
		count: Array.from(monthsMap.values()).reduce((sum, count) => sum + count, 0),
		months: Array.from(monthsMap.entries())
			.sort((a, b) => b[0] - a[0]) // Sort months descending
			.map(([month, count]) => ({ month, count })),
	}));

---

<PageLayout 
	title={SITE_TITLE} 
	description={SITE_DESCRIPTION}
	lang={lang}
	class="w-full max-w-[1400px] xl:max-w-[1600px] mx-auto py-3 md:py-8 px-0 md:px-4"
>
	<!-- Mobile Filter Button - Geek Style -->
	{sortedTags.length > 0 && (
		<button 
			id="mobile-filter-btn"
			class="lg:hidden fixed bottom-4 left-2 z-50 p-2.5 bg-background border border-accent/40 transition-all duration-200"
			aria-label={t('blog.filters')}
			style="transform: translateX(0);"
		>
			<Icon name="ph:funnel" class="w-5 h-5 text-accent glow-icon" />
		</button>
	)}

	<!-- Mobile Filter Overlay -->
	{sortedTags.length > 0 && (
		<div 
			id="mobile-filter-overlay"
			class="lg:hidden fixed inset-0 bg-background/95 backdrop-blur-sm z-[60] opacity-0 pointer-events-none transition-opacity duration-300"
		>
			<div class="h-full overflow-y-auto p-4 pb-20 relative">
				<div class="flex justify-between items-center mb-4 relative z-[61]">
					<h2 class="text-xl font-semibold text-foreground flex items-center gap-2">
						<Icon name="ph:funnel" class="w-5 h-5 text-accent glow-icon" />
						{t('blog.filters')}
					</h2>
					<button 
						id="mobile-filter-close"
						class="p-2 hover:bg-foreground/10 transition-colors relative z-[61]"
						aria-label="Close filters"
					>
						<Icon name="ph:x" class="w-6 h-6 text-foreground" />
					</button>
				</div>
				
				<!-- Tags Section -->
				<div class="mb-6">
					<div class="flex items-center justify-between mb-3">
						<h3 class="text-sm font-semibold text-foreground flex items-center gap-2">
							<Icon name="ph:folder" class="w-4 h-4 text-accent glow-icon" />
							{t('blog.tags')}
						</h3>
						<button 
							id="clear-tags-filter-mobile"
							class="clear-filter-btn"
							title={t('blog.clearTags')}
							style="visibility: hidden; opacity: 0; pointer-events: none;"
						>
							<Icon name="ph:x" class="w-3.5 h-3.5" />
						</button>
					</div>
					<ul class="tags-list">
						{sortedTags.map(({ tag, count }) => (
							<li>
								<button
									class="blog-tag"
									data-tag={tag}
								>
									<span class="tag-name">{tag}</span>
									<span class="tag-count">{count}</span>
								</button>
							</li>
						))}
					</ul>
				</div>

				<!-- Date Section -->
				{sortedDateGroups.length > 0 && (
					<div>
						<div class="flex items-center justify-between mb-3">
							<h3 class="text-sm font-semibold text-foreground flex items-center gap-2">
								<Icon name="ph:calendar-blank" class="w-4 h-4 text-accent glow-icon" />
								{t('blog.date')}
							</h3>
							<button 
								id="clear-date-filter-mobile"
								class="clear-filter-btn"
								title={t('blog.clearDate')}
								style="visibility: hidden; opacity: 0; pointer-events: none;"
							>
								<Icon name="ph:x" class="w-3.5 h-3.5" />
							</button>
						</div>
						<nav class="date-filter-nav">
							<ul class="date-list">
								{sortedDateGroups.map(({ year, count, months }, index) => (
									<li class="year-group">
										<button
											class="year-button mobile"
											data-year={year}
											data-expanded={index === 0 ? 'true' : 'false'}
										>
											<span class="year-indicator">></span>
											<span class="year-label">{year}</span>
											<span class="year-count">{count}</span>
										</button>
										<ul class="month-list" style={index === 0 ? '' : 'display: none;'}>
											{months.map(({ month, count }) => (
												<li>
													<button
														class="month-button mobile"
														data-year={year}
														data-month={month}
													>
														<span class="month-name">{monthNames[month - 1]}</span>
														<span class="month-count">{count}</span>
													</button>
												</li>
											))}
										</ul>
									</li>
								))}
							</ul>
						</nav>
					</div>
				)}
			</div>
		</div>
	)}

	<div class="blog-layout">
		<!-- Desktop Filter Card (Tags) -->
		{sortedTags.length > 0 && (
			<Card class="filter-card hidden lg:block lg:sticky lg:top-4 lg:self-start">
				<div class="flex items-center gap-2 mb-3">
					<Icon name="ph:folder" class="w-4 h-4 text-accent glow-icon" />
					<span class="text-sm font-semibold text-foreground">{t('blog.filterLabel')}</span>
					<button 
						id="clear-tags-filter-desktop"
						class="clear-filter-btn"
						title={t('blog.clearTags')}
						style="visibility: hidden; opacity: 0; pointer-events: none;"
					>
						<Icon name="ph:x" class="w-3.5 h-3.5" />
					</button>
				</div>
				<ul class="tags-list">
					{sortedTags.map(({ tag, count }) => (
						<li>
							<button
								class="blog-tag"
								data-tag={tag}
							>
								<span class="tag-name">{tag}</span>
								<span class="tag-count">{count}</span>
							</button>
						</li>
					))}
				</ul>
			</Card>
		)}

		<!-- Posts Card -->
		<Card class="blog-posts-card">
			<CardHeader title={t('blog.posts')} icon="rss" />
			<div class="content-container">
				{posts.map((post) => (
					<a 
						href={getRelativeLocaleUrl(lang, `/blog/${getPostBaseId(post)}/`)}
						class="post-container"
						data-tags={(post.data.tags || []).join(',')}
						data-year={post.data.pubDate.getFullYear()}
						data-month={post.data.pubDate.getMonth() + 1}
					>
						{post.data.heroImage && (
							<div class="post-hero-image">
								<Image 
									src={post.data.heroImage} 
									alt={post.data.title}
									width={800}
									height={400}
									loading="lazy"
									class="hero-img"
								/>
							</div>
						)}
						<div class="post-header">
							<h3>{post.data.title}</h3>
							<span class="post-date">
								<FormattedDate date={post.data.pubDate} lang={lang} />
							</span>
						</div>
						{post.data.description && (
							<span class="post-description">
								{stripMarkdown(post.data.description)}
							</span>
						)}
					</a>
				))}
			</div>
		</Card>

		<!-- Desktop Date Filter Sidebar (Right) - ToC Style -->
		{sortedDateGroups.length > 0 && (
			<aside class="date-filter hidden xl:block xl:sticky xl:top-4 xl:self-start">
				<div class="date-filter-header">
					<div class="flex items-center gap-2">
						<Icon name="ph:calendar-blank" class="w-4 h-4 text-accent glow-icon" />
						<span>{t('blog.dateFilter')}</span>
					</div>
					<button 
						id="clear-date-filter-desktop"
						class="clear-filter-btn"
						title={t('blog.clearDate')}
						style="visibility: hidden; opacity: 0; pointer-events: none;"
					>
						<Icon name="ph:x" class="w-3.5 h-3.5" />
					</button>
				</div>
				<nav class="date-filter-nav">
					<ul class="date-list">
						{sortedDateGroups.map(({ year, count, months }, index) => (
							<li class="year-group">
								<button
									class="year-button"
									data-year={year}
									data-expanded={index === 0 ? 'true' : 'false'}
								>
									<span class="year-indicator">></span>
									<span class="year-label">{year}</span>
									<span class="year-count">{count}</span>
								</button>
								<ul class="month-list" style={index === 0 ? '' : 'display: none;'}>
									{months.map(({ month, count }) => (
										<li>
											<button
												class="month-button"
												data-year={year}
												data-month={month}
											>
												<span class="month-name">{monthNames[month - 1]}</span>
												<span class="month-count">{count}</span>
											</button>
										</li>
									))}
								</ul>
							</li>
						))}
					</ul>
				</nav>
			</aside>
		)}
	</div>
</PageLayout>

<style>
	/* Tags List */
	.tags-list {
		display: flex;
		flex-direction: row;
		align-items: center;
		flex-wrap: wrap;
		list-style-type: none;
		margin: 0;
		padding: 0;
		gap: 0.5rem;
	}

	/* Geek Style Tag - Glow Effect (No Border) */
	.blog-tag {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem 0.5rem;
		background: transparent;
		color: var(--color-foreground);
		text-decoration: none;
		border: none;
		cursor: pointer;
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 0.8125rem;
		position: relative;
	}

	.blog-tag::before {
		content: '';
		position: absolute;
		inset: -6px;
		background: radial-gradient(
			ellipse 100% 60% at 50% 50%,
			color-mix(in srgb, var(--color-accent) 10%, transparent),
			transparent 70%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		filter: blur(6px);
		z-index: -1;
	}

	/* Only apply hover effects on devices that support hover */
	@media (hover: hover) {
		.blog-tag:hover,
		.blog-tag:focus-visible {
			color: var(--color-accent);
		}

		.blog-tag:hover::before,
		.blog-tag:focus-visible::before {
			opacity: 0.5;
		}
	}

	.blog-tag.active {
		color: var(--color-accent);
		font-weight: 600;
	}

	.blog-tag.active::before {
		opacity: 1;
	}

	.tag-count {
		font-size: 0.6875rem;
		padding: 0.0625rem 0.25rem;
		background: color-mix(in srgb, var(--color-foreground) 15%, transparent);
		font-weight: 600;
		min-width: 1rem;
		text-align: center;
	}

	.blog-tag.active .tag-count {
		background: color-mix(in srgb, var(--color-accent) 25%, transparent);
		color: var(--color-accent);
	}

	/* Glow effect for icons - consistent with CardHeader */
	.glow-icon {
		filter: drop-shadow(0 0 4px var(--color-accent));
	}

	/* Content Container */
	.content-container {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.post-container {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		padding: 1rem 0.75rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
		text-decoration: none;
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		margin: 0;
		overflow: hidden;
	}

	/* Hero Image Styles */
	.post-hero-image {
		width: 100%;
		margin-bottom: 0.75rem;
		border-radius: 4px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.hero-img {
		width: 100%;
		height: auto;
		display: block;
		transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);
		object-fit: cover;
		aspect-ratio: 2 / 1;
	}

	.post-container:hover .post-hero-image,
	.post-container:focus-visible .post-hero-image {
		border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
		box-shadow: 0 0 20px color-mix(in srgb, var(--color-primary) 15%, transparent);
	}

	.post-container:hover .hero-img,
	.post-container:focus-visible .hero-img {
		transform: scale(1.05);
	}

	@media (min-width: 640px) {
		.post-container {
			padding: 1.25rem;
			margin: 0 -0.5rem;
		}
	}

	.post-container::before {
		content: '';
		position: absolute;
		inset: -20px;
		background: radial-gradient(
			ellipse 80% 50% at 50% 50%,
			color-mix(in srgb, var(--color-primary) 15%, transparent),
			transparent 70%
		);
		opacity: 0;
		transition: opacity 400ms ease;
		pointer-events: none;
		filter: blur(20px);
	}

	.post-container:last-child {
		border-bottom: none;
	}

	.post-container:hover,
	.post-container:focus-visible {
		background-color: color-mix(in srgb, var(--color-primary) 3%, transparent);
		border-color: transparent;
		box-shadow: 
			0 0 40px color-mix(in srgb, var(--color-primary) 12%, transparent),
			inset 0 0 20px color-mix(in srgb, var(--color-primary) 5%, transparent);
	}

	.post-container:hover::before,
	.post-container:focus-visible::before {
		opacity: 1;
	}

	.post-header {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.post-header h3 {
		margin: 0;
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--color-foreground);
		line-height: 1.5;
		transition: color 200ms ease;
	}

	.post-container:hover .post-header h3,
	.post-container:focus-visible .post-header h3 {
		color: var(--color-primary-light);
	}

	.post-date {
		font-size: 0.8125rem;
		color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
		font-weight: 500;
		letter-spacing: 0.01em;
		transition: color 200ms ease;
	}

	.post-container:hover .post-date,
	.post-container:focus-visible .post-date {
		color: color-mix(in srgb, var(--color-primary) 70%, var(--color-foreground) 30%);
	}

	.post-description {
		font-size: 0.875rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
		margin: 0;
		transition: color 200ms ease;
	}

	.post-container:hover .post-description,
	.post-container:focus-visible .post-description {
		color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
	}

	@media (min-width: 640px) {
		.post-header {
			flex-direction: row;
			justify-content: space-between;
			align-items: baseline;
		}

		.post-date {
			flex-shrink: 0;
		}
	}

	/* Blog Layout - Three Column on XL screens */
	.blog-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
	}

	@media (min-width: 1024px) {
		.blog-layout {
			grid-template-columns: 1fr 2fr;
			gap: 1rem;
		}
	}

	@media (min-width: 1280px) {
		.blog-layout {
			grid-template-columns: 1fr 2fr 274px;
			gap: 1rem;
		}
	}

	@media (min-width: 1536px) {
		.blog-layout {
			grid-template-columns: 1fr 2fr 320px;
			gap: 1.25rem;
		}
	}

	/* Date Filter Sidebar - ToC Style */
	.date-filter {
		position: relative;
		color: color-mix(in srgb, var(--color-foreground) 90%, transparent);
		font-size: 0.875rem;
		opacity: 0.9;
	}

	.date-filter-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-foreground);
		font-size: 0.875rem;
	}

	.date-filter-nav {
		width: 100%;
		font-size: 0.875rem;
	}

	.date-list {
		list-style-type: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.year-group {
		list-style-type: none;
	}

	/* Year Button - Geek Style with Glow */
	.year-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 0.5rem;
		background: transparent;
		color: var(--color-foreground);
		border: none;
		cursor: pointer;
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 0.875rem;
		font-weight: 600;
		width: 100%;
		position: relative;
	}

	.year-button::before {
		content: '';
		position: absolute;
		inset: -8px;
		background: radial-gradient(
			ellipse 100% 60% at 50% 50%,
			color-mix(in srgb, var(--color-accent) 12%, transparent),
			transparent 70%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		filter: blur(8px);
		z-index: -1;
	}

	@media (hover: hover) {
		.year-button:hover {
			color: var(--color-accent);
		}

		.year-button:hover::before {
			opacity: 0.6;
		}
	}

	.year-indicator {
		color: var(--color-accent);
		font-weight: 700;
		transition: transform 150ms ease;
		display: inline-block;
		width: 1rem;
		text-align: center;
	}

	.year-button[data-expanded="true"] .year-indicator {
		transform: rotate(90deg);
	}

	.year-label {
		flex: 1;
		text-align: left;
	}

	.year-count {
		font-size: 0.75rem;
		padding: 0.125rem 0.375rem;
		background: color-mix(in srgb, var(--color-foreground) 10%, transparent);
		font-weight: 600;
		min-width: 1.5rem;
		text-align: center;
	}

	/* Month List */
	.month-list {
		list-style-type: none;
		margin: 0.25rem 0 0 0;
		padding: 0 0 0 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	/* Month Button - Geek Style with Glow */
	.month-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.25rem 0.5rem;
		background: transparent;
		color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
		border: none;
		cursor: pointer;
		transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
		font-size: 0.8125rem;
		width: 100%;
		position: relative;
	}

	.month-button::before {
		content: '';
		position: absolute;
		inset: -6px;
		background: radial-gradient(
			ellipse 100% 60% at 50% 50%,
			color-mix(in srgb, var(--color-accent) 10%, transparent),
			transparent 70%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		filter: blur(6px);
		z-index: -1;
	}

	@media (hover: hover) {
		.month-button:hover {
			color: var(--color-accent);
		}

		.month-button:hover::before {
			opacity: 0.5;
		}
	}

	.month-button.active {
		color: var(--color-accent);
		font-weight: 600;
	}

	.month-button.active::before {
		opacity: 1;
	}

	.month-name {
		flex: 1;
		text-align: left;
	}

	.month-count {
		font-size: 0.6875rem;
		padding: 0.0625rem 0.3rem;
		background: color-mix(in srgb, var(--color-foreground) 10%, transparent);
		font-weight: 600;
		min-width: 1.25rem;
		text-align: center;
	}

	.month-button.active .month-count {
		background: color-mix(in srgb, var(--color-accent) 20%, transparent);
		color: var(--color-accent);
	}

	/* Clear Filter Button */
	.clear-filter-btn {
		padding: 0.25rem;
		background: transparent;
		border: none;
		color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
		cursor: pointer;
		transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 1.75rem;
		min-height: 1.75rem;
	}

	.clear-filter-btn:hover {
		background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
		color: var(--color-accent);
	}

	/* Year button active state (when year is selected) */
	.year-button.active {
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		color: var(--color-accent);
	}

	.year-button.active .year-count {
		background: color-mix(in srgb, var(--color-accent) 20%, transparent);
		color: var(--color-accent);
	}
</style>

<script>
	const tags = document.querySelectorAll<HTMLButtonElement>('.blog-tag');
	const posts = document.querySelectorAll<HTMLAnchorElement>('.post-container');
	const url = new URL(window.location.href);
	const initialTags = url.searchParams.get('tags')?.split(',').filter((tag) => tag.length > 0) || [];
	const selectedTags = new Set(initialTags);

	// Tag filter elements
	const clearTagsDesktop = document.getElementById('clear-tags-filter-desktop');
	const clearTagsMobile = document.getElementById('clear-tags-filter-mobile');

	// Date filter state
	const initialYear = url.searchParams.get('year');
	const initialMonth = url.searchParams.get('month');
	let selectedYear: number | null = initialYear ? parseInt(initialYear) : null;
	let selectedMonth: number | null = initialMonth ? parseInt(initialMonth) : null;

	// Date filter elements
	const yearButtons = document.querySelectorAll<HTMLButtonElement>('.year-button');
	const monthButtons = document.querySelectorAll<HTMLButtonElement>('.month-button');

	// Mobile filter controls
	const mobileFilterBtn = document.getElementById('mobile-filter-btn');
	const mobileFilterOverlay = document.getElementById('mobile-filter-overlay');
	const mobileFilterClose = document.getElementById('mobile-filter-close');

	function openMobileFilter() {
		if (mobileFilterOverlay) {
			mobileFilterOverlay.classList.remove('pointer-events-none', 'opacity-0');
			mobileFilterOverlay.classList.add('pointer-events-auto', 'opacity-100');
			document.body.style.overflow = 'hidden';
		}
	}

	function closeMobileFilter() {
		if (mobileFilterOverlay) {
			mobileFilterOverlay.classList.add('pointer-events-none', 'opacity-0');
			mobileFilterOverlay.classList.remove('pointer-events-auto', 'opacity-100');
			document.body.style.overflow = '';
		}
	}

	function toggleMobileFilter() {
		if (mobileFilterOverlay?.classList.contains('pointer-events-none')) {
			openMobileFilter();
		} else {
			closeMobileFilter();
		}
	}

	mobileFilterBtn?.addEventListener('click', toggleMobileFilter);
	mobileFilterClose?.addEventListener('click', closeMobileFilter);
	
	// Close on overlay click (but not on content click)
	mobileFilterOverlay?.addEventListener('click', (e) => {
		if (e.target === mobileFilterOverlay) {
			closeMobileFilter();
		}
	});

	function updateTagClearButtonVisibility() {
		const hasTagFilter = selectedTags.size > 0;
		if (clearTagsDesktop) {
			clearTagsDesktop.style.visibility = hasTagFilter ? 'visible' : 'hidden';
			clearTagsDesktop.style.opacity = hasTagFilter ? '1' : '0';
			clearTagsDesktop.style.pointerEvents = hasTagFilter ? 'auto' : 'none';
		}
		if (clearTagsMobile) {
			clearTagsMobile.style.visibility = hasTagFilter ? 'visible' : 'hidden';
			clearTagsMobile.style.opacity = hasTagFilter ? '1' : '0';
			clearTagsMobile.style.pointerEvents = hasTagFilter ? 'auto' : 'none';
		}
	}

	function clearTagFilter() {
		selectedTags.clear();
		tags.forEach((tag) => tag.classList.remove('active'));
		updatePostsVisibility();
		updateURL();
		updateTagClearButtonVisibility();
	}

	// Close on escape key
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') {
			closeMobileFilter();
		}
	});

	// Hide button while scrolling, show when stopped
	let isScrolling = false;
	let scrollStopTimer: ReturnType<typeof setTimeout> | null = null;

	window.addEventListener('scroll', () => {
		// Hide button immediately when scrolling starts
		if (!isScrolling && mobileFilterBtn) {
			isScrolling = true;
			mobileFilterBtn.style.transform = 'translateX(-85%)';
		}
		
		// Clear previous timer
		if (scrollStopTimer) {
			clearTimeout(scrollStopTimer);
		}
		
		// Show button after scrolling stops
		scrollStopTimer = setTimeout(() => {
			isScrolling = false;
			if (mobileFilterBtn) {
				mobileFilterBtn.style.transform = 'translateX(0)';
			}
		}, 150);
	});

	function updatePostsVisibility() {
		posts.forEach((post) => {
			const postTags = post.dataset.tags!.split(',').filter(t => t.length > 0);
			const postYear = parseInt(post.dataset.year!);
			const postMonth = parseInt(post.dataset.month!);
			
			let matchesTags = true;
			let matchesDate = true;
			
			// Check tags filter
			if (selectedTags.size > 0) {
				matchesTags = [...selectedTags].every((tag) => postTags.includes(tag));
			}
			
			// Check date filter
			if (selectedYear !== null) {
				if (selectedMonth !== null) {
					// Both year and month selected
					matchesDate = postYear === selectedYear && postMonth === selectedMonth;
				} else {
					// Only year selected
					matchesDate = postYear === selectedYear;
				}
			}
			
			// Show only if matches both filters (AND logic)
			if (matchesTags && matchesDate) {
				post.style.display = '';
			} else {
				post.style.display = 'none';
			}
		});
	}

	function updateURL() {
		const newUrl = new URL(window.location.pathname, window.location.origin);
		if (selectedTags.size > 0) {
			newUrl.searchParams.set('tags', [...selectedTags].join(','));
		}
		if (selectedYear !== null) {
			newUrl.searchParams.set('year', selectedYear.toString());
		}
		if (selectedMonth !== null) {
			newUrl.searchParams.set('month', selectedMonth.toString());
		}
		history.pushState({}, '', newUrl);
	}

	tags.forEach((tag) => {
		const tagValue = tag.dataset.tag!;
		if (selectedTags.has(tagValue)) {
			tag.classList.add('active');
		}

		tag.addEventListener('click', (event) => {
			event.preventDefault();

			tag.classList.toggle('active');

			if (selectedTags.has(tagValue)) {
				selectedTags.delete(tagValue);
			} else {
				selectedTags.add(tagValue);
			}

			updatePostsVisibility();
			updateURL();
			updateTagClearButtonVisibility();
		});
	});

	// Clear tag filter buttons
	clearTagsDesktop?.addEventListener('click', clearTagFilter);
	clearTagsMobile?.addEventListener('click', clearTagFilter);

	// Clear date filter buttons
	const clearDateDesktop = document.getElementById('clear-date-filter-desktop');
	const clearDateMobile = document.getElementById('clear-date-filter-mobile');

	function updateClearButtonVisibility() {
		const isDateFilterActive = selectedYear !== null;
		if (clearDateDesktop) {
			clearDateDesktop.style.visibility = isDateFilterActive ? 'visible' : 'hidden';
			clearDateDesktop.style.opacity = isDateFilterActive ? '1' : '0';
			clearDateDesktop.style.pointerEvents = isDateFilterActive ? 'auto' : 'none';
		}
		if (clearDateMobile) {
			clearDateMobile.style.visibility = isDateFilterActive ? 'visible' : 'hidden';
			clearDateMobile.style.opacity = isDateFilterActive ? '1' : '0';
			clearDateMobile.style.pointerEvents = isDateFilterActive ? 'auto' : 'none';
		}
	}

	function updateYearButtonStates() {
		yearButtons.forEach((btn) => {
			const year = parseInt(btn.dataset.year!);
			if (selectedYear === year && selectedMonth === null) {
				btn.classList.add('active');
			} else {
				btn.classList.remove('active');
			}
		});
	}

	function clearDateFilter() {
		selectedYear = null;
		selectedMonth = null;
		monthButtons.forEach(btn => btn.classList.remove('active'));
		updateYearButtonStates();
		updateClearButtonVisibility();
		updatePostsVisibility();
		updateURL();
	}

	// Clear button event listeners
	clearDateDesktop?.addEventListener('click', clearDateFilter);
	clearDateMobile?.addEventListener('click', clearDateFilter);

	// Year button interactions - click year to filter + expand (accordion effect)
	yearButtons.forEach((yearBtn) => {
		const year = parseInt(yearBtn.dataset.year!);
		const monthList = yearBtn.nextElementSibling as HTMLElement;
		
		// Set initial active state
		if (selectedYear === year && selectedMonth === null) {
			yearBtn.classList.add('active');
			yearBtn.dataset.expanded = 'true';
			if (monthList) monthList.style.display = '';
		}
		
		// Click anywhere on year button
		yearBtn.addEventListener('click', (e) => {
			e.preventDefault();
			const isExpanded = yearBtn.dataset.expanded === 'true';
			const isSameYear = selectedYear === year && selectedMonth === null;
			
			// Accordion effect: close all other years
			yearButtons.forEach(btn => {
				const otherYear = parseInt(btn.dataset.year!);
				if (otherYear !== year) {
					btn.dataset.expanded = 'false';
					const otherMonthList = btn.nextElementSibling as HTMLElement;
					if (otherMonthList) otherMonthList.style.display = 'none';
				}
			});
			
			// If clicking the same year that's already selected, deselect and collapse
			if (isSameYear && isExpanded) {
				selectedYear = null;
				selectedMonth = null;
				yearBtn.dataset.expanded = 'false';
				if (monthList) monthList.style.display = 'none';
			} else {
				// Select this year and expand
				monthButtons.forEach(btn => btn.classList.remove('active'));
				selectedYear = year;
				selectedMonth = null;
				yearBtn.dataset.expanded = 'true';
				if (monthList) monthList.style.display = '';
			}
			
			updateYearButtonStates();
			updateClearButtonVisibility();
			updatePostsVisibility();
			updateURL();
		});
	});

	// Month button interactions
	monthButtons.forEach((monthBtn) => {
		const year = parseInt(monthBtn.dataset.year!);
		const month = parseInt(monthBtn.dataset.month!);
		
		// Set initial active state
		if (selectedYear === year && selectedMonth === month) {
			monthBtn.classList.add('active');
		}
		
		monthBtn.addEventListener('click', (e) => {
			e.preventDefault();
			
			// If clicking the same month, deselect it
			if (selectedYear === year && selectedMonth === month) {
				selectedYear = null;
				selectedMonth = null;
				monthBtn.classList.remove('active');
			} else {
				// Deselect all months first
				monthButtons.forEach(btn => btn.classList.remove('active'));
				
				// Select this month
				selectedYear = year;
				selectedMonth = month;
				monthBtn.classList.add('active');
			}
			
			updateYearButtonStates();
			updateClearButtonVisibility();
			updatePostsVisibility();
			updateURL();
		});
	});

	// Initialize
	updateTagClearButtonVisibility();
	updateClearButtonVisibility();
	updateYearButtonStates();
	updatePostsVisibility();
</script>
