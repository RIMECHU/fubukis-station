---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/Card.astro';
import CardHeader from '../components/CardHeader.astro';
import LinkCard from '../components/LinkCard.astro';
import { SITE_TITLE } from '../consts';
import { getLinksByLang } from '../config/links';
import { defaultLang, resolveLang, useTranslations } from '../i18n/config';
import type { Lang } from '../i18n/config';

// Seeded random number generator (using mulberry32)
function seededRandom(seed: number) {
	return function() {
		seed = (seed + 0x6D2B79F5) | 0;
		let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
		t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
}

// Shuffle array with seeded random
function shuffleWithSeed<T>(array: T[], seed: number): T[] {
	const shuffled = [...array];
	const rng = seededRandom(seed);
	
	for (let i = shuffled.length - 1; i > 0; i--) {
		const j = Math.floor(rng() * (i + 1));
		[shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
	}
	
	return shuffled;
}

// Get current 30-minute window as seed
// This ensures the order changes every 30 minutes but stays the same within each 30-minute window
const thirtyMinutesInMs = 30 * 60 * 1000;
const seed = Math.floor(Date.now() / thirtyMinutesInMs);


const { lang: langProp } = Astro.props as { lang?: Lang };
const lang = langProp ?? resolveLang(Astro.url.pathname) ?? defaultLang;

// Shuffle the links list
const shuffledLinks = shuffleWithSeed(getLinksByLang(lang), seed);

const t = useTranslations(lang);
---

<PageLayout 
	title={`${t('links.friends.title')} - ${SITE_TITLE}`} 
	description={t('links.friends.description')}
	lang={lang}
	class="w-full max-w-[960px] mx-auto py-3 md:py-8 px-0 md:px-4"
>
	<Card>
		<CardHeader title={t('links.friends.title')} icon="heart" />
		<div class="links-container">
			{shuffledLinks.map((link) => (
				<LinkCard {...link} />
			))}
		</div>
	</Card>
</PageLayout>

<style>
	.links-container {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		padding: 0;
	}

	@media (min-width: 768px) {
		.links-container {
			grid-template-columns: repeat(1, 1fr);
			gap: 1rem;
		}
	}
</style>
