---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Background from '../components/Background.astro';
import { ClientRouter } from 'astro:transitions';
import { getRelativeLocaleUrl } from 'astro:i18n';
import MusicPlayer from '../components/MusicPlayer.astro';
import Giscus from '../components/Giscus.astro';
import ShareButton from '../components/ShareButton.astro';
import { defaultLang, resolveLang, useTranslations, type Lang } from '../i18n/config';

type Props = Partial<CollectionEntry<'blog'>['data']> & {
	title: string;
	description: string;
	headings?: any[];
	showTitle?: boolean;
  	lang?: Lang;
};

const { title, description, pubDate, updatedDate, heroImage, headings = [], showTitle = true, lang: langProp } = Astro.props;
const lang = langProp ?? resolveLang(Astro.url.pathname) ?? defaultLang;
const blogUrl = getRelativeLocaleUrl(lang, 'blog');
const t = useTranslations(lang);
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
			<ClientRouter />
	</head>

	<body>
		<Background />
		<Header lang={lang} />
		<main class="blog-post-main-with-toc">
			<article class="blog-article-wrapper">
				{heroImage && (
					<div class="hero-image blog-post-hero">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose blog-post-prose">
					<a href={blogUrl} class="blog-back-link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>{t("blog.back")}</a>
					{(showTitle || pubDate || updatedDate) && (
						<div class="title blog-post-title">
							{(pubDate || updatedDate) && (
								<div class="date blog-post-date">
									{pubDate && <FormattedDate date={pubDate} lang={lang} />}
									{updatedDate && (
										<div class="last-updated-on blog-post-last-updated">
											{t('blog.lastUpdated')} <FormattedDate date={updatedDate} lang={lang} />
										</div>
									)}
								</div>
							)}
							{showTitle && <h1>{title}</h1>}
							{showTitle && <hr />}
						</div>
					)}
					<slot />
				</div>
			</article>
			<TableOfContents headings={headings} lang={lang} />
		</main>
		<ShareButton lang={lang} />
		<Giscus />
		<Footer lang={lang} />
		<MusicPlayer />
	</body>
</html>
