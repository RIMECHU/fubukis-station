---
/**
 * PageLayout
 * Unified page layout with header and footer
 * Replaces repetitive HTML structure across pages
 */

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import { ClientRouter } from 'astro:transitions';
import { defaultLang, resolveLang } from '../i18n/config';

interface Props {
	title: string;
	description: string;
	class?: string;
	showFooter?: boolean;
	lang?: string;
}

const { title, description, class: className, showFooter = false, lang: langProp } = Astro.props;
const lang = langProp ?? resolveLang(Astro.url.pathname) ?? defaultLang;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
		<ClientRouter />
	</head>
	<body class="font-sans">
		<slot name="overlay" />
		<Background />
		<Header lang={lang} />
		<main class={className}>
			<slot />
		</main>
		{showFooter && <Footer lang={lang} />}
		<MusicPlayer />
	</body>
</html>
